# ── Storage ────────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database. Default: data/benchmarks.db in project root.
BENCHMARK_DB_PATH=

# Path for the live CSV export (read by other agents). Default: data/benchmarks.csv
BENCHMARK_CSV_PATH=

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=benchmarks
EMBED_MODEL=BAAI/bge-small-en-v1.5
# Set to false to disable Qdrant (FTS5-only mode)
QDRANT_ENABLED=true

# ── MCP HTTP server ────────────────────────────────────────────────────────────
# Caddy (included in docker-compose) terminates TLS — MCP binds to 0.0.0.0 internally.
MCP_HOST=0.0.0.0
MCP_PORT=8765
# Bearer API key for HTTP transport. Set a strong random value.
MCP_API_KEY=

# Domain for Caddy auto-HTTPS via Let's Encrypt.
# - Set to your domain (e.g. mcp.example.com) → free TLS cert, no warnings.
# - Leave empty / localhost → self-signed cert (add allowInsecureCertificate:true in VS Code).
MCP_DOMAIN=

# ── Ingest REST API ────────────────────────────────────────────────────────────
INGEST_HOST=127.0.0.1
INGEST_PORT=8766
INGEST_API_KEY=

# ── Telegram bot (optional) ────────────────────────────────────────────────────
BENCHMARK_BOT_TOKEN=
ALLOWED_USER_ID=

# ── Fetcher ────────────────────────────────────────────────────────────────────
FETCH_TIMEOUT=10
FETCH_USER_AGENT=Mozilla/5.0 (OpenBenchmark/1.0; +https://github.com/open-benchmark)

# ── Feature flags ──────────────────────────────────────────────────────────────
# Enable trafilatura for readable content extraction (requires trafilatura package)
FEATURE_TRAFILATURA=true
# Enable GitHub API enrichment for github.com URLs
FEATURE_GITHUB_EXTRACTOR=true
# Enable lightweight knowledge graph (stores in SQLite)
FEATURE_GRAPH=true

# ── Knowledge graph ────────────────────────────────────────────────────────────
GRAPH_SIMILARITY_THRESHOLD=0.80
GRAPH_DUPLICATE_THRESHOLD=0.92
